APP_NAME=Bolo
DEBUG=false
SECRET_KEY=<generate-with: python -c "import secrets; print(secrets.token_hex(32))">

# Set by Railway automatically — override if needed
DATABASE_URL=<Railway PostgreSQL URL>
DATABASE_SYNC_URL=<Railway PostgreSQL URL — replace asyncpg with psycopg2>
REDIS_URL=<Railway Redis URL>
CELERY_BROKER_URL=<Railway Redis URL — db 1>
CELERY_RESULT_BACKEND=<Railway Redis URL — db 2>

OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o
SENTIMENT_MODEL=gpt-4o-mini

SARVAM_API_KEY=sk_...
SARVAM_API_BASE=https://api.sarvam.ai
SARVAM_STT_MODEL=saaras:v2
SARVAM_STT_WITH_DIARIZATION=false
SARVAM_TTS_MODEL=bulbul:v1

PINECONE_API_KEY=pcsk_...
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=bolo-knowledge

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...

# Optional — leave blank to use local /media storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=bolo-audio

STT_PROVIDER=sarvam
UVICORN_WORKERS=2

# Set to your Vercel frontend URL + Railway backend URL
CORS_ORIGINS=["https://bolo.vercel.app","https://your-custom-domain.com"]
