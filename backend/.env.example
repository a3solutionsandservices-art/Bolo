APP_NAME=VaaniAI
DEBUG=false
SECRET_KEY=your-super-secret-key-here

DATABASE_URL=postgresql+asyncpg://vaaniai:vaaniai@localhost:5432/vaaniai
DATABASE_SYNC_URL=postgresql://vaaniai:vaaniai@localhost:5432/vaaniai
TEST_DATABASE_URL=postgresql+asyncpg://vaaniai:vaaniai@localhost:5432/vaaniai_test
REDIS_URL=redis://localhost:6379/0

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

SARVAM_API_KEY=your-sarvam-api-key
SARVAM_API_BASE=https://api.sarvam.ai
SARVAM_STT_MODEL=saaras:v2
SARVAM_STT_WITH_DIARIZATION=false
SARVAM_TTS_MODEL=bulbul:v1

GOOGLE_TRANSLATE_API_KEY=your-google-translate-key

PINECONE_API_KEY=your-pinecone-key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=vaaniai-knowledge

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...

AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=vaaniai-audio

STT_PROVIDER=sarvam
STT_FALLBACK_PROVIDER=whisper
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_WEBHOOK_SECRET=your-twilio-webhook-secret

FASTTEXT_MODEL_PATH=models/lid.176.bin
INDICTRANS_DEVICE=cpu

CORS_ORIGINS=["http://localhost:3000","https://app.vaaniai.com"]
API_BASE_URL=https://api.vaaniai.com
